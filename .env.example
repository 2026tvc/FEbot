# Slack（Socket Mode）
SLACK_TOKEN=
SLACK_APP_TOKEN=

# OpenAI 互換 API（埋め込み＋チャット）。空のままでも Slack 接続・練習問題・/fe-help は動作（RAG 応答のみオフ）
AI_API_KEY=
# 省略時は OpenAI 公式。Azure 等はベース URL を指定
# AI_BASE_URL=https://api.openai.com/v1

# 任意（デフォルトは下記コメント相当）
# AI_CHAT_MODEL=gpt-4o-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_PATH=./data/chroma
# CORPUS_DIR=./data/corpus
# RAG_TOP_K=5
# ベクトル検索のコサイン距離上限（小さいほど厳しい）。無関係な ipa チャンクを減らす。無効化: RAG_MAX_DISTANCE=off
# RAG_MAX_DISTANCE=0.52
# 検索プール倍率（大きいほど距離フィルタ前に多く読む）
# RAG_POOL_MULT=5
# Slack ユーザーごとの1分あたりRAG呼び出し上限
# RATE_LIMIT_PER_MINUTE=20

# Web 検索フォールバック（DuckDuckGo、APIキー不要）
# ナレッジベースに該当情報がないときに自動で Web 検索し、結果をコーパスに保存します
# WEB_SEARCH_MAX_RESULTS=5
# Bedrock移行用途の旧キー（現行パイプライン未使用）
# AWS_BEARER_TOKEN_BEDROCK=

SUPABASE_URL=
SUPABASE_KEY=
